# =====================================================
# Python bytecode and cache
# =====================================================
__pycache__/
*.py[cod]
*$py.class

# =====================================================
# Virtual environments
# =====================================================
venv/
env/
ENV/
.venv/

# =====================================================
# Jupyter Notebook checkpoints
# =====================================================
.ipynb_checkpoints/

# =====================================================
# Environment variables and secrets
# =====================================================
.env
.env.*
*.env

# =====================================================
# Flask instance folder
# =====================================================
instance/

# =====================================================
# Uploaded user files
# =====================================================
uploads/
static/uploads/

# Keep the folder structure even if empty
!uploads/.gitkeep
!static/uploads/.gitkeep

# =====================================================
# Logs and temporary files
# =====================================================
*.log
logs/
tmp/
temp/

# =====================================================
# Operating system files
# =====================================================
.DS_Store
Thumbs.db
desktop.ini

# =====================================================
# IDE and editor settings
# =====================================================
.vscode/
.idea/
*.swp
*.swo

# =====================================================
# Testing and coverage
# =====================================================
.pytest_cache/
.coverage
htmlcov/

# =====================================================
# Build and distribution
# =====================================================
build/
dist/
*.egg-info/
.eggs/

# =====================================================
# Machine learning models (uncomment if models are large
# and can be regenerated or downloaded separately)
# =====================================================
# *.h5
# *.keras
# *.pkl
# *.joblib
# *.pt
# *.pth

# =====================================================
# Data files (optional - uncomment if datasets are large)
# =====================================================
# data/
# datasets/

# =====================================================
# Package manager lock files (optional)
# =====================================================
# Pipfile.lock
# poetry.lock